# ─── Anthropic Claude API ─────────────────────────────────────────────────────
# Used for all AI synthesis, signal classification, and battlecard generation
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Zoho CRM OAuth 2.0 ───────────────────────────────────────────────────────
# Generate refresh token at: https://api-console.zoho.com
# Required scopes: ZohoCRM.modules.ALL, ZohoCRM.settings.ALL, ZohoCRM.bulk.ALL
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_REFRESH_TOKEN=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Slack Webhooks ───────────────────────────────────────────────────────────
# Sales channel (#bd-intel): raw deal alerts, tender deadlines, competitor moves
SLACK_SALES_WEBHOOK=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXX
# Exec channel (#leadership-intel): digest summaries only
SLACK_EXEC_WEBHOOK=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXX

# ─── AWS SES (Monthly Exec Email Briefing) ────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AWS_REGION=eu-west-1

# ─── Email Recipients ─────────────────────────────────────────────────────────
SES_SENDER=intelligence@descasio.io
# Comma-separated list of executive recipients
EXEC_RECIPIENTS=ceo@descasio.io,coo@descasio.io,cso@descasio.io,cto@descasio.io
